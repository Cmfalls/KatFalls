---
import { books } from '../data/books';

const findBook = (slug: string) => books.find((book) => book.slug === slug)!;

const slides = [
  {
    eyebrow: 'Middle Grade Adventure',
    title: 'Dark Life Series',
    description:
      'Kat Falls\' subsea adventure series for middle grade readers, where ocean-floor settlers, pirates, and dark gifts collide.',
    href: '/series/dark-life',
    cta: 'Explore Dark Life',
    video: '/images/author/DLHero1 (1).mp4',
    poster: '/images/books/DLBG1.jpg',
    featuredBooks: [findBook('dark-life'), findBook('rip-tide')],
  },
  {
    eyebrow: 'Young Adult Dystopia',
    title: 'Inhuman Series',
    description:
      'A dystopian YA journey beyond the wall, where mutation, survival, and impossible choices reshape everything.',
    href: '/series/inhuman',
    cta: 'Explore Inhuman',
    video: '/images/author/InhumanHero2.mp4',
    poster: '/images/books/InhumanBG2.png',
    featuredBooks: [findBook('inhuman'), findBook('undaunted')],
  },
];
---

<section class="hero-slider" data-hero-slider>
  <div class="hero-slider__slides">
    {slides.map((slide, index) => (
      <article
        class={`hero-slide ${index === 0 ? 'is-active' : ''}`}
        data-slide
        aria-hidden={index === 0 ? 'false' : 'true'}
      >
        <div class="hero-slide__media" aria-hidden="true">
          <video
            class="hero-slide__video"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster={slide.poster}
          >
            <source src={slide.video} type="video/mp4" />
          </video>
          <div class="hero-slide__overlay"></div>
        </div>

        <div class="hero-slide__inner">
          <div class="hero-slide__copy">
            <p class="hero-slide__eyebrow">{slide.eyebrow}</p>
            <h1 class="hero-slide__title">{slide.title}</h1>
            <p class="hero-slide__description">{slide.description}</p>
            <a href={slide.href} class="hero-slide__cta">{slide.cta}</a>
          </div>

          <div class="hero-slide__books" aria-label={`${slide.title} featured books`}>
            {slide.featuredBooks.map((book) => (
              <a href={`/books/${book.slug}`} class="hero-book-card">
                <img
                  src={book.coverImage}
                  alt={`Cover of ${book.title}`}
                  class="hero-book-card__cover"
                  loading="eager"
                />
                <span class="hero-book-card__title">{book.title}</span>
              </a>
            ))}
          </div>
        </div>
      </article>
    ))}
  </div>

  <div class="hero-slider__nav" aria-label="Homepage featured series">
    {slides.map((slide, index) => (
      <button
        type="button"
        class={`hero-slider__dot ${index === 0 ? 'is-active' : ''}`}
        data-slide-trigger={index}
        aria-label={`Show slide ${index + 1}: ${slide.title}`}
        aria-pressed={index === 0 ? 'true' : 'false'}
      ></button>
    ))}
  </div>
</section>

<script>
  const slider = document.querySelector('[data-hero-slider]');

  if (slider) {
    const slides = Array.from(slider.querySelectorAll('[data-slide]'));
    const triggers = Array.from(slider.querySelectorAll('[data-slide-trigger]'));
    let activeIndex = 0;
    let intervalId;

    const setActiveSlide = (nextIndex) => {
      activeIndex = nextIndex;

      slides.forEach((slide, index) => {
        const isActive = index === activeIndex;
        slide.classList.toggle('is-active', isActive);
        slide.setAttribute('aria-hidden', isActive ? 'false' : 'true');
      });

      triggers.forEach((trigger, index) => {
        const isActive = index === activeIndex;
        trigger.classList.toggle('is-active', isActive);
        trigger.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });
    };

    const startAutoAdvance = () => {
      window.clearInterval(intervalId);
      intervalId = window.setInterval(() => {
        const nextIndex = (activeIndex + 1) % slides.length;
        setActiveSlide(nextIndex);
      }, 7000);
    };

    triggers.forEach((trigger, index) => {
      trigger.addEventListener('click', () => {
        setActiveSlide(index);
        startAutoAdvance();
      });
    });

    setActiveSlide(0);
    startAutoAdvance();
  }
</script>

<style>
  .hero-slider {
    position: relative;
    overflow: hidden;
    background: #0f5357;
  }

  .hero-slider__slides {
    position: relative;
    min-height: clamp(30rem, 68vh, 44rem);
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.7s ease;
  }

  .hero-slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .hero-slide__media,
  .hero-slide__video,
  .hero-slide__overlay {
    position: absolute;
    inset: 0;
  }

  .hero-slide__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-slide__overlay {
    background:
      linear-gradient(90deg, rgba(7, 29, 32, 0.84) 0%, rgba(7, 29, 32, 0.62) 45%, rgba(7, 29, 32, 0.34) 100%),
      linear-gradient(180deg, rgba(7, 29, 32, 0.12) 0%, rgba(7, 29, 32, 0.44) 100%);
  }

  .hero-slide__inner {
    position: relative;
    z-index: 1;
    max-width: 80rem;
    margin: 0 auto;
    min-height: clamp(30rem, 68vh, 44rem);
    padding: 5rem 1.5rem 6rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
  }

  .hero-slide__copy {
    max-width: 40rem;
    color: #f7f0e6;
  }

  .hero-slide__books {
    display: grid;
    grid-template-columns: repeat(2, minmax(9rem, 11rem));
    gap: 1rem;
    align-items: start;
    justify-content: end;
  }

  .hero-book-card {
    display: block;
    padding: 0.9rem;
    border-radius: 1.2rem;
    background: rgba(9, 32, 35, 0.58);
    border: 1px solid rgba(247, 240, 230, 0.14);
    text-decoration: none;
    color: #f7f0e6;
    box-shadow: 0 22px 45px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(8px);
    transition: transform 0.25s ease, border-color 0.25s ease, background-color 0.25s ease;
  }

  .hero-book-card:hover {
    transform: translateY(-4px);
    border-color: rgba(213, 174, 79, 0.55);
    background: rgba(9, 32, 35, 0.72);
  }

  .hero-book-card__cover {
    display: block;
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    border-radius: 0.95rem;
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.34);
  }

  .hero-book-card__title {
    display: block;
    margin-top: 0.95rem;
    font-family: "Playfair Display", serif;
    font-size: 1.45rem;
    line-height: 1.1;
  }

  .hero-slide__eyebrow {
    margin-bottom: 0.8rem;
    font-size: 0.74rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #d5ae4f;
  }

  .hero-slide__title {
    margin: 0;
    font-family: "Playfair Display", serif;
    font-size: clamp(3rem, 5vw, 5.25rem);
    line-height: 0.95;
    text-wrap: balance;
  }

  .hero-slide__description {
    margin-top: 1.3rem;
    max-width: 34rem;
    font-size: 1.05rem;
    line-height: 1.75;
    color: rgba(247, 240, 230, 0.85);
  }

  .hero-slide__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 2rem;
    padding: 0.95rem 1.5rem;
    border-radius: 999px;
    background: #d5ae4f;
    color: #12393d;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .hero-slide__cta:hover {
    transform: translateY(-1px);
    background: #e1bb61;
  }

  .hero-slider__nav {
    position: absolute;
    left: 50%;
    bottom: 1.75rem;
    z-index: 2;
    display: flex;
    gap: 0.7rem;
    transform: translateX(-50%);
  }

  .hero-slider__dot {
    width: 0.8rem;
    height: 0.8rem;
    border: 0;
    border-radius: 999px;
    background: rgba(247, 240, 230, 0.35);
    cursor: pointer;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .hero-slider__dot.is-active {
    background: #d5ae4f;
    transform: scale(1.15);
  }

  @media (max-width: 640px) {
    .hero-slider__slides,
    .hero-slide__inner {
      min-height: 28rem;
    }

    .hero-slide__inner {
      padding-top: 4rem;
      padding-bottom: 5rem;
    }

    .hero-slide__description {
      font-size: 0.98rem;
      line-height: 1.6;
    }
  }

  @media (max-width: 1100px) {
    .hero-slide__inner {
      gap: 2rem;
    }

    .hero-slide__books {
      grid-template-columns: repeat(2, minmax(8rem, 9.5rem));
    }

    .hero-book-card__title {
      font-size: 1.2rem;
    }
  }

  @media (max-width: 900px) {
    .hero-slide__inner {
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
    }

    .hero-slide__copy {
      max-width: 36rem;
    }

    .hero-slide__books {
      width: 100%;
      justify-content: start;
      grid-template-columns: repeat(2, minmax(8.5rem, 10rem));
    }
  }
</style>
