---
import BaseLayout from '@layouts/BaseLayout.astro';
import RetailerRail from '@components/RetailerRail.astro';
import ReviewQuote from '@components/ReviewQuote.astro';
import { books } from '../../data/books';
import { buildBookPageSchema } from '../../data/structuredData';

const book = books.find((entry) => entry.slug === 'dark-life')!;
const heroImage = '/images/books/DLBG1.jpg';

const darkLifeRetailers = [
  {
    name: 'Amazon',
    href: 'https://www.amazon.com/Dark-Life-Book-Kat-Falls/dp/B005SN6WMO/ref=sr_1_2?s=books&ie=UTF8&qid=1325979122&sr=1-2',
    priority: true,
  },
  {
    name: 'Barnes & Noble',
    href: 'https://www.barnesandnoble.com/w/dark-life-kat-falls/1101011783?ean=9780545178150',
    priority: true,
  },
  {
    name: 'Bookshop.org',
    href: 'https://bookshop.org/p/books/dark-life-kat-falls/cfd5b916776b76d6?ean=9780545178150&next=t&next=t&source=IndieBound&ref=https%3A%2F%2Fwww.katfalls.net%2F',
    priority: true,
  },
  {
    name: 'Audio Sample',
    href: 'https://www.amazon.com/arya/webplayer?asin=B0036FJ962&marketplaceId=ATVPDKIKX0DER&amazonAsin=B003KJM5GU&useRelativeUrl=true&initialCPLaunch=true&isSample=true&isHomesteadCaller=true&isMobile=false&ref_=adbl_dp_dt_cloudplayer_anon',
    priority: false,
  },
];

const schema = buildBookPageSchema(book, {
  audience: { min: 9, max: 12 },
  breadcrumbs: [
    { name: 'Home', path: '/' },
    { name: 'Books', path: '/books' },
    { name: 'Dark Life Series', path: '/series/dark-life' },
    { name: 'Dark Life', path: '/books/dark-life' },
  ],
  genre: 'Middle Grade Sci-Fi Adventure',
  seriesName: 'Dark Life Series',
  seriesPath: '/series/dark-life',
});
---

<BaseLayout
  title="Dark Life by Kat Falls - Dark Life Series Book 1"
  description={book.shortSynopsis}
  schema={schema}
>
  <section class="relative isolate overflow-hidden bg-brand-dark text-brand-warm">
    <div class="absolute inset-0" aria-hidden="true">
      <img
        src={heroImage}
        alt=""
        class="h-full w-full object-cover object-center opacity-55"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-dark/80 via-brand-dark/72 to-brand-dark/52"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/78 via-brand-dark/22 to-brand-dark/6"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-6 py-16 grid md:grid-cols-3 gap-10 items-start">
      <div class="md:col-span-1">
        <div class="aspect-[2/3] bg-brand-mid rounded-sm shadow-2xl overflow-hidden">
          <img
            src={book.coverImage}
            alt={`${book.title} cover`}
            class="w-full h-full object-cover"
            onerror="this.classList.add('hidden'); if (this.nextElementSibling) this.nextElementSibling.classList.remove('hidden');"
          />
          <div class="hidden w-full h-full flex items-center justify-center text-center p-6">
            <div>
              <p class="text-xs uppercase tracking-widest text-brand-gold mb-2">Dark Life #1</p>
              <p class="font-serif text-brand-warm text-2xl">{book.title}</p>
              <p class="text-xs text-brand-warm/30 mt-2">Cover coming soon</p>
            </div>
          </div>
        </div>
        <div class="mt-6">
          <RetailerRail isbn={book.isbn} title={book.title} overrides={darkLifeRetailers} />
        </div>
      </div>

      <div class="md:col-span-2">
        <nav class="text-xs text-brand-warm/40 mb-4">
          <a href="/books" class="hover:text-brand-warm transition-colors">Books</a>
          <span class="mx-2">&rsaquo;</span>
          <a href="/series/dark-life" class="hover:text-brand-warm transition-colors">Dark Life Series</a>
          <span class="mx-2">&rsaquo;</span>
          <span class="text-brand-warm/70">{book.title}</span>
        </nav>

        <p class="text-xs uppercase tracking-widest text-brand-gold mb-2">Dark Life Series, Book 1</p>
        <h1 class="text-5xl font-serif mb-3">{book.title}</h1>
        <p class="text-brand-accent font-serif text-xl italic mb-6">{book.tagline}</p>

        <div class="flex flex-wrap gap-4 text-xs text-brand-warm/60 mb-8 uppercase tracking-wide">
          <span>{book.publisher}</span>
          <span>&middot;</span>
          <span>{book.pubDate}</span>
          <span>&middot;</span>
          <span>{book.ageRange}</span>
          <span>&middot;</span>
          <span>{book.gradeRange}</span>
          {book.lexile && <><span>&middot;</span><span>Lexile {book.lexile}</span></>}
          {book.atos && <><span>&middot;</span><span>ATOS {book.atos}</span></>}
        </div>

        <p class="text-brand-warm/80 leading-relaxed text-lg mb-6">{book.shortSynopsis}</p>

        <div class="flex flex-wrap gap-2 mb-8">
          {book.awards.slice(0, 5).map((award) => (
            <span class="text-xs bg-brand-gold/10 text-brand-gold border border-brand-gold/30 px-3 py-1 rounded-sm">{award}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-container grid md:grid-cols-3 gap-10">
    <div class="md:col-span-2">
      <h2 class="font-serif text-2xl text-brand-dark mb-4">About the Book</h2>
      <p class="text-brand-dark/80 leading-relaxed text-lg mb-6">{book.longSynopsis}</p>

      <div class="grid gap-6 lg:grid-cols-2 mb-10">
        <div class="p-5 bg-white shadow-sm rounded-sm border border-brand-dark/5">
          <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-3 font-semibold">Editorial Take</h3>
          <p class="text-sm text-brand-dark/70 leading-relaxed">
            Trade reviewers consistently framed <em>Dark Life</em> as a fast-moving undersea Western: strong action, vivid worldbuilding, and a setting that makes the ocean floor feel dangerous, cinematic, and original.
          </p>
          <p class="text-sm text-brand-dark/70 leading-relaxed mt-3">
            The strongest praise in the notes you shared centers on Ty and Gemma, the subsea frontier premise, and the way marine science details make the book easy to hand to adventure readers and reluctant readers alike.
          </p>
        </div>

        <div class="p-5 bg-white shadow-sm rounded-sm border border-brand-dark/5">
          <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-3 font-semibold">Reader Reaction</h3>
          <p class="text-sm text-brand-dark/70 leading-relaxed">
            Recent reader feedback highlights the underwater setting, brisk pacing, and science-fiction adventure blend. The recurring themes are immersive ocean worldbuilding, clean middle grade accessibility, and a story that moves quickly into danger and mystery.
          </p>
          <div class="flex flex-wrap gap-2 mt-4">
            {['Underwater worldbuilding', 'Action', 'Mystery', 'Science themes', 'Strong pacing', 'Ages 9-12'].map((tag) => (
              <span class="text-xs bg-brand-accent/10 text-brand-accent border border-brand-accent/20 px-3 py-1 rounded-sm">{tag}</span>
            ))}
          </div>
        </div>
      </div>

      <h3 class="font-serif text-xl text-brand-dark mt-8 mb-4">What Reviewers Said</h3>
      {book.reviews.map((review) => (
        <ReviewQuote quote={review.quote} source={review.source} date={review.date} starred={review.starred} />
      ))}

      <h3 class="font-serif text-xl text-brand-dark mt-8 mb-4">Awards &amp; Recognition</h3>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        {book.awards.map((award) => (
          <li class="flex items-start gap-2 text-sm text-brand-dark/70">
            <span class="text-brand-gold mt-0.5">✦</span>
            {award}
          </li>
        ))}
      </ul>
    </div>

    <aside class="space-y-6">
      <div class="p-5 bg-white shadow-sm rounded-sm border border-brand-dark/5">
        <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-3 font-semibold">Book Details</h3>
        <dl class="space-y-2 text-sm">
          <div><dt class="text-brand-dark/40">Publisher</dt><dd class="text-brand-dark">{book.publisher}</dd></div>
          <div><dt class="text-brand-dark/40">Published</dt><dd class="text-brand-dark">{book.pubDate}</dd></div>
          <div><dt class="text-brand-dark/40">Edition</dt><dd class="text-brand-dark">1st</dd></div>
          <div><dt class="text-brand-dark/40">Print Length</dt><dd class="text-brand-dark">304 pages</dd></div>
          <div><dt class="text-brand-dark/40">Reading Age</dt><dd class="text-brand-dark">9-12 years</dd></div>
          <div><dt class="text-brand-dark/40">Grade Level</dt><dd class="text-brand-dark">4-7</dd></div>
          {book.lexile && <div><dt class="text-brand-dark/40">Lexile</dt><dd class="text-brand-dark">{book.lexile}</dd></div>}
          {book.atos && <div><dt class="text-brand-dark/40">ATOS Level</dt><dd class="text-brand-dark">{book.atos}</dd></div>}
          <div><dt class="text-brand-dark/40">ASIN</dt><dd class="text-brand-dark font-mono text-xs">B005SN6WMO</dd></div>
          <div><dt class="text-brand-dark/40">ISBN</dt><dd class="text-brand-dark font-mono text-xs">9780545178150</dd></div>
          <div><dt class="text-brand-dark/40">Series</dt><dd class="text-brand-dark">Book 1 of 2</dd></div>
        </dl>
        {book.contentNotes && (
          <div class="mt-4 pt-4 border-t border-brand-dark/10">
            <dt class="text-xs uppercase tracking-widest text-brand-accent mb-1 font-semibold">Content Notes</dt>
            <dd class="text-xs text-brand-dark/60">{book.contentNotes}</dd>
          </div>
        )}
      </div>

      <div class="p-5 bg-white shadow-sm rounded-sm border border-brand-dark/5">
        <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-3 font-semibold">Why It Lands</h3>
        <ul class="space-y-2 text-sm text-brand-dark/70">
          <li>Underwater frontier premise with a clear hook from page one.</li>
          <li>Adventure-heavy middle grade pacing with mystery and pirate pressure.</li>
          <li>Marine biology atmosphere and subsea survival details readers remember.</li>
          <li>Strong crossover appeal for sci-fi, action, and reluctant-reader audiences.</li>
        </ul>
      </div>

      <div class="p-5 bg-brand-dark text-brand-warm rounded-sm">
        <h3 class="text-xs uppercase tracking-widest text-brand-gold mb-3 font-semibold">For Educators</h3>
        <p class="text-xs text-brand-warm/70 mb-3 leading-relaxed">Discussion guide, STEM tie-ins, and Common Core-aligned lesson plans available free.</p>
        <a href="/for-educators#dark-life" class="text-xs uppercase tracking-widest text-brand-gold font-semibold hover:underline">Get Resources &rarr;</a>
      </div>

      <div class="p-5 bg-brand-warm border border-brand-dark/10 rounded-sm">
        <p class="font-serif text-brand-dark mb-1">Continue the series</p>
        <a href="/books/rip-tide" class="flex items-center gap-2 text-sm text-brand-dark hover:text-brand-accent transition-colors">
          <span class="text-brand-accent">&rarr;</span> Rip Tide (Book 2)
        </a>
      </div>
    </aside>
  </section>
</BaseLayout>
