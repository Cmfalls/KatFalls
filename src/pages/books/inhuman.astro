---
import BaseLayout from '@layouts/BaseLayout.astro';
import RetailerRail from '@components/RetailerRail.astro';
import ReviewQuote from '@components/ReviewQuote.astro';
import { books } from '../../data/books';
import { buildBookPageSchema } from '../../data/structuredData';

const book = books.find((entry) => entry.slug === 'inhuman')!;
const heroImage = '/images/books/InhumanBG.png';

const inhumanRetailers = [
  {
    name: 'Amazon Hardcover',
    href: 'https://www.amazon.com/Inhuman-Kat-Falls/dp/054537099X/ref=tmm_hrd_swatch_0',
    priority: true,
  },
  {
    name: 'Amazon Kindle',
    href: 'https://www.amazon.com/Inhuman-Kat-Falls-ebook/dp/B00B9FX5ES/ref=sr_1_2?dchild=1&keywords=inhuman&qid=1588003416&sr=8-2',
    priority: true,
  },
  {
    name: 'Barnes & Noble',
    href: 'https://www.barnesandnoble.com/w/inhuman-kat-falls/1113024070?ean=9780545520348',
    priority: true,
  },
  {
    name: 'Bookshop.org',
    href: 'https://bookshop.org/p/books/inhuman-kat-falls/02e3b8676275a88e?ean=9780545371018&next=t&next=t&source=IndieBound&ref=https%3A%2F%2Fwww.katfalls.net%2F',
    priority: true,
  },
  {
    name: 'First Look Excerpt',
    href: 'https://www.scribd.com/document/149271986/First-Look-Inhuman-by-Kat-Falls?ad_group=725X1342X25c21a3e9a4fdabbfafcf9da55227455&campaign=SkimbitLtd&keyword=660149026&medium=affiliate&source=hp_affiliate',
    priority: false,
  },
];

const schema = buildBookPageSchema(book, {
  audience: { min: 13, max: 18 },
  breadcrumbs: [
    { name: 'Home', path: '/' },
    { name: 'Books', path: '/books' },
    { name: 'Inhuman Series', path: '/series/inhuman' },
    { name: 'Inhuman', path: '/books/inhuman' },
  ],
  genre: 'Young Adult Dystopian Science Fiction',
  seriesName: 'Inhuman Series',
  seriesPath: '/series/inhuman',
});
---

<BaseLayout
  title="Inhuman by Kat Falls - Inhuman Series Book 1"
  description={book.shortSynopsis}
  schema={schema}
>
  <section class="relative isolate overflow-hidden bg-brand-dark text-brand-warm">
    <div class="absolute inset-0" aria-hidden="true">
      <img
        src={heroImage}
        alt=""
        class="h-full w-full object-cover object-center opacity-50"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-dark/76 via-brand-dark/66 to-brand-dark/50"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/74 via-brand-dark/20 to-brand-dark/6"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-6 py-16 grid md:grid-cols-3 gap-10 items-start">
      <div class="md:col-span-1">
        <div class="aspect-[2/3] bg-brand-mid rounded-sm shadow-2xl overflow-hidden">
          <img
            src={book.coverImage}
            alt={`${book.title} cover`}
            class="w-full h-full object-cover"
            onerror="this.classList.add('hidden'); if (this.nextElementSibling) this.nextElementSibling.classList.remove('hidden');"
          />
          <div class="hidden w-full h-full flex items-center justify-center text-center p-6">
            <div>
              <p class="text-xs uppercase tracking-widest text-brand-gold mb-2">Kirkus Starred</p>
              <p class="font-serif text-brand-warm text-2xl">{book.title}</p>
              <p class="text-xs text-brand-warm/30 mt-2">Cover coming soon</p>
            </div>
          </div>
        </div>
        <div class="mt-6">
          <RetailerRail isbn={book.isbn} title={book.title} overrides={inhumanRetailers} />
        </div>
      </div>

      <div class="md:col-span-2">
        <nav class="text-xs text-brand-warm/40 mb-4">
          <a href="/books" class="hover:text-brand-warm transition-colors">Books</a>
          <span class="mx-2">&rsaquo;</span>
          <a href="/series/inhuman" class="hover:text-brand-warm transition-colors">Inhuman Series</a>
          <span class="mx-2">&rsaquo;</span>
          <span class="text-brand-warm/70">{book.title}</span>
        </nav>

        <p class="text-xs uppercase tracking-widest text-brand-gold mb-2">Inhuman Series, Book 1</p>
        <h1 class="text-5xl font-serif mb-3">{book.title}</h1>
        <p class="text-brand-accent font-serif text-xl italic mb-6">{book.tagline}</p>

        <div class="flex flex-wrap gap-4 text-xs text-brand-warm/60 mb-8 uppercase tracking-wide">
          <span>{book.publisher}</span>
          <span>&middot;</span>
          <span>{book.pubDate}</span>
          <span>&middot;</span>
          <span>{book.ageRange}</span>
          <span>&middot;</span>
          <span>{book.gradeRange}</span>
          {book.lexile && <><span>&middot;</span><span>Lexile {book.lexile}</span></>}
          {book.atos && <><span>&middot;</span><span>ATOS {book.atos}</span></>}
        </div>

        <p class="text-brand-warm/80 leading-relaxed text-lg mb-6">{book.shortSynopsis}</p>

        <div class="p-4 border border-brand-accent/40 rounded-sm mb-6">
          <p class="text-xs uppercase tracking-widest text-brand-accent mb-1 font-semibold">Kirkus Starred Review</p>
          <p class="font-serif italic text-brand-warm/80 text-sm">
            &ldquo;Sure to satisfy fans of the dystopian-romance genre and to gather new ones along the way.&rdquo;
          </p>
        </div>

        <div class="flex flex-wrap gap-2 mb-4">
          {book.awards.map((award) => (
            <span class="text-xs bg-brand-gold/10 text-brand-gold border border-brand-gold/30 px-3 py-1 rounded-sm">{award}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-container grid md:grid-cols-3 gap-10">
    <div class="md:col-span-2">
      <h2 class="font-serif text-2xl text-brand-dark mb-4">About the Book</h2>
      <p class="text-brand-dark/80 leading-relaxed text-lg mb-6">{book.longSynopsis}</p>

      <div class="grid gap-6 lg:grid-cols-2 mb-10">
        <div class="p-5 bg-white shadow-sm rounded-sm border border-brand-dark/5">
          <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-3 font-semibold">Editorial Take</h3>
          <p class="text-sm text-brand-dark/70 leading-relaxed">
            <em>Inhuman</em> is positioned as a harsher, older-leaning Kat Falls adventure: quarantine dystopia, biological catastrophe, and a heroine forced out of safety and into a ruined world she has only feared from a distance.
          </p>
          <p class="text-sm text-brand-dark/70 leading-relaxed mt-3">
            The material you shared points to its strongest hook being the blend of fast dystopian momentum with creature-driven danger, romance tension, and the moral blur between the so-called civilized side of the wall and the world beyond it.
          </p>
        </div>

        <div class="p-5 bg-white shadow-sm rounded-sm border border-brand-dark/5">
          <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-3 font-semibold">Reader Reaction</h3>
          <p class="text-sm text-brand-dark/70 leading-relaxed">
            Reader response centers on the originality of the Feral Zone, the manimal concept, and Lane's voice under pressure. The repeated themes are intensity, unusual worldbuilding, and a story that keeps widening once Lane crosses the wall.
          </p>
          <div class="flex flex-wrap gap-2 mt-4">
            {['Dystopian tension', 'Biological disaster', 'Creature horror', 'Wall-crossing adventure', 'YA pacing', 'Ages 12+'].map((tag) => (
              <span class="text-xs bg-brand-accent/10 text-brand-accent border border-brand-accent/20 px-3 py-1 rounded-sm">{tag}</span>
            ))}
          </div>
        </div>
      </div>

      <h3 class="font-serif text-xl text-brand-dark mt-8 mb-4">What Reviewers Said</h3>
      {book.reviews.map((review) => (
        <ReviewQuote quote={review.quote} source={review.source} date={review.date} starred={review.starred} />
      ))}
    </div>

    <aside class="space-y-6">
      <div class="p-5 bg-white shadow-sm rounded-sm border border-brand-dark/5">
        <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-3 font-semibold">Book Details</h3>
        <dl class="space-y-2 text-sm">
          <div><dt class="text-brand-dark/40">Publisher</dt><dd class="text-brand-dark">{book.publisher}</dd></div>
          <div><dt class="text-brand-dark/40">Published</dt><dd class="text-brand-dark">{book.pubDate}</dd></div>
          <div><dt class="text-brand-dark/40">Print Length</dt><dd class="text-brand-dark">355 pages</dd></div>
          <div><dt class="text-brand-dark/40">Reading Age</dt><dd class="text-brand-dark">12 years and up</dd></div>
          <div><dt class="text-brand-dark/40">Grade Level</dt><dd class="text-brand-dark">7-9</dd></div>
          <div><dt class="text-brand-dark/40">Language</dt><dd class="text-brand-dark">English</dd></div>
          {book.lexile && <div><dt class="text-brand-dark/40">Lexile</dt><dd class="text-brand-dark">{book.lexile}</dd></div>}
          {book.atos && <div><dt class="text-brand-dark/40">ATOS Level</dt><dd class="text-brand-dark">{book.atos}</dd></div>}
          <div><dt class="text-brand-dark/40">ISBN</dt><dd class="text-brand-dark font-mono text-xs">{book.isbn}</dd></div>
          <div><dt class="text-brand-dark/40">Kindle ASIN</dt><dd class="text-brand-dark font-mono text-xs">B00B9FX5ES</dd></div>
          <div><dt class="text-brand-dark/40">Series</dt><dd class="text-brand-dark">Book 1 of 2</dd></div>
        </dl>
        {book.contentNotes && (
          <div class="mt-4 pt-4 border-t border-brand-dark/10">
            <dt class="text-xs uppercase tracking-widest text-brand-accent mb-1 font-semibold">Content Notes</dt>
            <dd class="text-xs text-brand-dark/60">{book.contentNotes}</dd>
          </div>
        )}
      </div>

      <div class="p-5 bg-white shadow-sm rounded-sm border border-brand-dark/5">
        <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-3 font-semibold">Preview the World</h3>
        <p class="text-sm text-brand-dark/70 leading-relaxed mb-3">
          A Scribd-hosted first-look excerpt is available if you want a quick sample before buying or teaching the book.
        </p>
        <a
          href="https://www.scribd.com/document/149271986/First-Look-Inhuman-by-Kat-Falls?ad_group=725X1342X25c21a3e9a4fdabbfafcf9da55227455&campaign=SkimbitLtd&keyword=660149026&medium=affiliate&source=hp_affiliate"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs uppercase tracking-widest text-brand-accent font-semibold hover:underline"
        >
          Read the First Look &rarr;
        </a>
      </div>

      <div class="p-5 bg-brand-dark text-brand-warm rounded-sm">
        <h3 class="text-xs uppercase tracking-widest text-brand-gold mb-3 font-semibold">For Educators</h3>
        <p class="text-xs text-brand-warm/70 mb-3">NGSS-aligned resources, bioethics discussion guide, free.</p>
        <a href="/for-educators#inhuman" class="text-xs uppercase tracking-widest text-brand-gold font-semibold hover:underline">Get Resources &rarr;</a>
      </div>

      <div class="p-5 bg-brand-warm border border-brand-dark/10 rounded-sm">
        <p class="font-serif text-brand-dark mb-1">Continue the series</p>
        <a href="/books/undaunted" class="flex items-center gap-2 text-sm text-brand-dark hover:text-brand-accent transition-colors">
          <span class="text-brand-accent">&rarr;</span> Undaunted (Book 2)
        </a>
      </div>
    </aside>
  </section>
</BaseLayout>
