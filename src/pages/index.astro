---

import BaseLayout from '@layouts/BaseLayout.astro';
import { books, series } from '../data/books';
import HeroSlider from '../components/HeroSlider.astro';

const darkLife = books.find(b => b.slug === 'dark-life')!;
const inhuman = books.find(b => b.slug === 'inhuman')!;
---

<BaseLayout
  title="Kat Falls - Dark Life & Inhuman Author"
  description="Official site of Kat Falls, author of the Dark Life middle grade series and the Inhuman YA series. Books, school visits, and educator resources."
>

  <!-- ═══════════════════════════════════════════════
       HERO SLIDER — new version
  ════════════════════════════════════════════════ -->
  <HeroSlider />

  <!-- ═══════════════════════════════════════════════
       AUDIENCE NAVIGATION — improved
  ════════════════════════════════════════════════ -->
  <section class="bg-brand-warm border-b border-brand-dark/10 py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-10">
        <p class="text-lg font-serif text-brand-dark/80 mb-2 tracking-wide">Find what you need:</p>
        <p class="text-2xl md:text-3xl font-bold text-brand-dark">Resources for Every Reader</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Tile 1: Young Readers -->
        <a href="/for-young-readers"
           class="group p-8 bg-white rounded-xl shadow-md hover:shadow-2xl transition-all border border-brand-dark/10 text-center hover:-translate-y-1 focus:outline-none focus:ring-2 focus:ring-brand-accent">
          <div class="w-16 h-16 mx-auto mb-5 rounded-full bg-brand-accent/10 flex items-center justify-center shadow-sm group-hover:bg-brand-accent/20 transition-colors">
            <svg class="w-8 h-8 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <h2 class="font-serif text-2xl font-bold text-brand-dark mb-2 group-hover:text-brand-accent transition-colors">For Young Readers</h2>
          <p class="text-base text-brand-dark/70 leading-relaxed mb-3">
            Read the first chapter free, explore the underwater world of <em>Dark Life</em>, and get writing tips from Kat.
          </p>
          <span class="inline-block mt-4 px-4 py-2 rounded-full bg-brand-accent/10 text-brand-accent text-xs font-semibold uppercase tracking-widest group-hover:bg-brand-accent group-hover:text-white transition-colors">Explore →</span>
        </a>
        <!-- Tile 2: Educators & Librarians -->
        <a href="/for-educators"
           class="group p-8 bg-white rounded-xl shadow-md hover:shadow-2xl transition-all border border-brand-dark/10 text-center hover:-translate-y-1 focus:outline-none focus:ring-2 focus:ring-brand-gold">
          <div class="w-16 h-16 mx-auto mb-5 rounded-full bg-brand-gold/10 flex items-center justify-center shadow-sm group-hover:bg-brand-gold/20 transition-colors">
            <svg class="w-8 h-8 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
            </svg>
          </div>
          <h2 class="font-serif text-2xl font-bold text-brand-dark mb-2 group-hover:text-brand-gold transition-colors">For Educators & Librarians</h2>
          <p class="text-base text-brand-dark/70 leading-relaxed mb-3">
            Free discussion guides, lesson plans aligned to Common Core ELA and NGSS, STEM tie-ins, and printable resources.
          </p>
          <span class="inline-block mt-4 px-4 py-2 rounded-full bg-brand-gold/10 text-brand-gold text-xs font-semibold uppercase tracking-widest group-hover:bg-brand-gold group-hover:text-white transition-colors">Get Resources →</span>
        </a>
        <!-- Tile 3: Parents & Gift-Buyers -->
        <a href="/books"
           class="group p-8 bg-white rounded-xl shadow-md hover:shadow-2xl transition-all border border-brand-dark/10 text-center hover:-translate-y-1 focus:outline-none focus:ring-2 focus:ring-brand-dark">
          <div class="w-16 h-16 mx-auto mb-5 rounded-full bg-brand-dark/10 flex items-center justify-center shadow-sm group-hover:bg-brand-dark/20 transition-colors">
            <svg class="w-8 h-8 text-brand-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
            </svg>
          </div>
          <h2 class="font-serif text-2xl font-bold text-brand-dark mb-2 group-hover:text-brand-dark transition-colors">For Parents & Gift-Buyers</h2>
          <p class="text-base text-brand-dark/70 leading-relaxed mb-3">
            Age-appropriate adventure with real science. See grade ranges, content notes, and buy from 8 retailers including your local indie.
          </p>
          <span class="inline-block mt-4 px-4 py-2 rounded-full bg-brand-dark/10 text-brand-dark text-xs font-semibold uppercase tracking-widest group-hover:bg-brand-dark group-hover:text-white transition-colors">Shop Books →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       THE TWO SERIES
  ════════════════════════════════════════════════ -->
  <section class="section-container">
    <p class="section-subheading">The Books</p>
    <h2 class="section-heading">Two Series. One Author.</h2>

    <div class="grid md:grid-cols-2 gap-8 mt-8">
      {series.map((s) => (
        <a href={s.path}
           class="group relative bg-brand-dark text-brand-warm rounded-sm overflow-hidden shadow-lg hover:shadow-2xl transition-shadow">
          <div class="p-8">
            <p class="text-xs uppercase tracking-widest text-brand-gold mb-2">{s.ageRange} · {s.genre}</p>
            <h3 class="font-serif text-3xl mb-3 group-hover:text-brand-gold transition-colors">{s.name} Series</h3>
            <p class="text-brand-warm/70 text-sm leading-relaxed mb-6">{s.tagline}</p>
            <span class="text-xs uppercase tracking-widest text-brand-accent font-semibold">Read the Series →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       CREDENTIALS STRIP
  ════════════════════════════════════════════════ -->
  <section class="bg-brand-mid text-brand-warm py-10">
    <div class="max-w-7xl mx-auto px-6">
      <ul class="flex flex-wrap justify-center gap-x-10 gap-y-3 text-xs text-brand-warm/60 uppercase tracking-widest text-center">
        <li class="font-semibold text-brand-gold">New York Times Bestselling Author</li>
        <li>Al Roker TODAY Show Pick</li>
        <li>Junior Library Guild Selection (×2)</li>
        <li>Kirkus Starred Review</li>
        <li>Friends of American Writers Award</li>
        <li>Disney Film Option</li>
        <li>~18 Language Translations</li>
        <li>10-State Award Nominations</li>
      </ul>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       LATEST STRIP (News + Events)
  ════════════════════════════════════════════════ -->
  <section class="section-container grid md:grid-cols-2 gap-12">
    <div>
      <p class="section-subheading">Latest</p>
      <h2 class="section-heading">News</h2>
      <p class="text-brand-dark/40 italic text-sm">No posts yet.</p>
      <a href="/news" class="btn-outline mt-6 inline-block text-sm">All News &amp; Events →</a>
    </div>
    <div>
      <p class="section-subheading">Upcoming</p>
      <h2 class="section-heading">Events</h2>
      <p class="text-brand-dark/40 italic text-sm">No upcoming events scheduled.</p>
      <a href="/school-visits" class="btn-outline mt-6 inline-block text-sm">Book a School Visit →</a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       ABOUT SNIPPET
  ════════════════════════════════════════════════ -->
  <section class="bg-brand-dark text-brand-warm">
    <div class="max-w-7xl mx-auto px-6 py-16 grid md:grid-cols-3 gap-12 items-center">
      <div class="md:col-span-2">
        <p class="section-subheading text-brand-gold">About the Author</p>
        <h2 class="text-4xl font-serif mb-4">Kathleen "Kat" Moynihan Falls</h2>
        <p class="text-brand-warm/80 leading-relaxed mb-2">
          Kat Falls holds an MFA in Writing for the Screen and Stage from Northwestern University, where she now teaches as faculty. A WGA member with screenwriting credits at Disney and four optioned independent screenplays, she lives in Evanston, Illinois.
        </p>
        <p class="text-brand-warm/70 text-sm leading-relaxed mb-6">
          She wrote the books her sons would actually read — and a generation of readers followed them underwater.
        </p>
        <a href="/about" class="btn-primary">Full Bio + FAQ</a>
      </div>
      <div class="hidden md:block">
        <img
          src="/images/author/kat-falls.jpg"
          alt="Kat Falls author photo"
          class="rounded-sm shadow-xl w-full object-cover max-h-72 object-top"
        />
      </div>
    </div>
  </section>

</BaseLayout>
