---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Kat Falls News - Announcements & Updates" description="Latest news, announcements, and updates from author Kat Falls.">
  <section class="bg-brand-dark text-brand-warm py-24">
    <div class="section-container">
      <p class="section-subheading text-brand-gold">Stay Up to Date</p>
      <h1 class="text-5xl md:text-6xl font-serif">News</h1>
    </div>
  </section>

  <section class="section-container max-w-3xl">
    <p class="text-brand-dark/40 italic text-center py-16">
      No posts yet. Add markdown files to <code>src/content/posts/</code> to populate this page.
    </p>
  </section>
</BaseLayout>
